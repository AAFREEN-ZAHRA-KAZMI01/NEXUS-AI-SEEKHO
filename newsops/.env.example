# NewsOps Intelligence API — Environment Configuration
# Copy this file to .env and fill in the values before running.

# ── Required ────────────────────────────────────────────────────────────────────
# Your Gemini API key. Get one at: https://aistudio.google.com/
# ⚠️  The server will refuse to start if this is left as the placeholder.
GEMINI_API_KEY=your_gemini_api_key_from_aistudio.google.com

# ── Database ────────────────────────────────────────────────────────────────────
# Local development (default):
DATABASE_URL=sqlite+aiosqlite:///./newsops.db
REDIS_URL=redis://localhost:6379/0
# Docker (maps to volume):
# DATABASE_URL=sqlite+aiosqlite:////app/data/newsops.db
# REDIS_URL=redis://redis:6379/0

# ── Server ──────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
DEMO_MODE=false

# Comma-separated list of allowed origins.
# Default covers common local-dev ports. In production, set explicit origins:
# ALLOWED_ORIGINS=https://your-app.com,https://api.your-app.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://10.0.2.2:8000

# ── Email Settings ──────────────────────────────────────────────────────────────
# Configure these to actually send emails for the simulation
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ── API Key Guard ────────────────────────────────────────────────────────────────
# Optional. When set, every API request must include the header:
#   X-API-Key: <value>
# Leave blank (or remove) in local development to disable the check.
# Generate a strong key for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
APP_API_KEY=

# ── Optional: override model names ──────────────────────────────────────────────
# MODEL_ORCHESTRATOR=gpt-4o
# MODEL_INGESTION=gpt-4o-mini
# MODEL_ANALYSIS=gpt-4o
# MODEL_DECISION=gpt-4o
# MODEL_RESEARCH=gpt-4o-mini
# MODEL_EXECUTION=gpt-4o-mini
